{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AI Agent Kit Registry Schema",
  "description": "Schema for registering AI agent skills, workflows, and MCP servers",
  "type": "object",
  "properties": {
    "version": {
      "type": "string",
      "description": "The registry format version"
    },
    "repo": {
      "type": "string",
      "description": "The GitHub repository containing this registry"
    },
    "skills": {
      "type": "object",
      "description": "Map of skill names to their configurations",
      "patternProperties": {
        "^[a-zA-Z0-9_-]+$": {
          "type": "object",
          "properties": {
            "source": {
              "type": "string",
              "description": "The local path or git URL to the skill"
            },
            "description": {
              "type": "string",
              "description": "A short description of the skill's purpose"
            },
            "tags": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "List of keywords categorizing the skill"
            },
            "version": {
              "type": "string",
              "description": "The semantic version of the skill"
            }
          },
          "required": [
            "source",
            "description"
          ],
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "workflows": {
      "type": "object",
      "description": "Map of workflow names to their configurations",
      "patternProperties": {
        "^[a-zA-Z0-9_-]+$": {
          "type": "object",
          "properties": {
            "source": {
              "type": "string",
              "description": "The local path or git URL to the workflow"
            },
            "description": {
              "type": "string",
              "description": "A short description of the workflow's goal"
            },
            "tags": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "List of keywords categorizing the workflow"
            }
          },
          "required": [
            "source",
            "description"
          ],
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "mcp": {
      "type": "object",
      "description": "Map of MCP server names to their configurations",
      "patternProperties": {
        "^[a-zA-Z0-9_-]+$": {
          "type": "object",
          "properties": {
            "package": {
              "type": "string",
              "description": "The npm package name of the MCP server"
            },
            "description": {
              "type": "string",
              "description": "A short description of the MCP server capabilities"
            }
          },
          "required": [
            "package",
            "description"
          ],
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "required": [
    "version",
    "repo",
    "skills",
    "workflows",
    "mcp"
  ],
  "additionalProperties": false
}

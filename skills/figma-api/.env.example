# Figma API — Environment Variables
# Copy this file to .env and fill in your values

# Required: Personal access token from https://www.figma.com/developers/api#access-tokens
FIGMA_TOKEN=figd_YOUR_TOKEN_HERE

# Required: File ID from the Figma URL
# Example: https://www.figma.com/design/Vi8yLE5reGrNXWfICflWAG → Vi8yLE5reGrNXWfICflWAG
FIGMA_FILE_ID=YOUR_FILE_ID_HERE

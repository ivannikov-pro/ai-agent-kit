{
  "name": "@ivannikov-pro/ai-agent-kit",
  "version": "0.1.0",
  "description": "CLI + MCP server for installing AI agent skills, workflows, and MCP configs",
  "type": "module",
  "bin": {
    "ai-agent-kit": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/"
  },
  "keywords": [
    "ai-agent",
    "agent-skills",
    "cli",
    "mcp"
  ],
  "author": "ivannikov-pro",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ivannikov-pro/ai-agent-kit.git",
    "directory": "packages/cli"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "ora": "^8.2.0",
    "zod": "^3.25.17"
  },
  "devDependencies": {
    "@ivannikov-pro/config-eslint": "workspace:*",
    "@types/node": "^22.15.0",
    "eslint": "^9.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.8.3"
  }
}
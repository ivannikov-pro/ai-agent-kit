{
  "name": "@ivannikov-pro/agent-kit",
  "version": "0.1.0",
  "description": "CLI + MCP server for installing AI agent skills, workflows, and MCP configs",
  "type": "module",
  "bin": {
    "agent-kit": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    }
  },
  "files": [
    "dist",
    "registry.json"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai-agent",
    "agent-skills",
    "agentskills",
    "cli",
    "mcp",
    "skills",
    "workflows"
  ],
  "author": "ivannikov-pro",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ivannikov-pro/agent-kit.git"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "ora": "^8.2.0",
    "zod": "^3.25.17"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsup": "^8.5.1",
    "typescript": "^5.8.3"
  }
}

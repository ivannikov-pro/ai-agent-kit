{
  "name": "ai-agent-kit",
  "version": "0.1.0",
  "private": true,
  "description": "🛠️ CLI + MCP server + web catalog for AI agent skills, workflows, and MCP configs",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "registry:build": "node scripts/update-registry.mjs",
    "registry:validate": "node scripts/update-registry.mjs --strict",
    "prepare": "husky"
  },
  "keywords": [
    "ai-agent",
    "agent-skills",
    "agentskills",
    "cli",
    "mcp",
    "skills",
    "workflows"
  ],
  "author": "ivannikov-pro",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ivannikov-pro/ai-agent-kit.git"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.9",
  "devDependencies": {
    "husky": "^9.1.7",
    "js-yaml": "^4.1.1",
    "lint-staged": "^16.4.0",
    "turbo": "^2.5.4"
  },
  "lint-staged": {
    "*.{ts,js,mjs,tsx,jsx}": "eslint --fix"
  }
}
